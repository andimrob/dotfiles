{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "respectGitignore": true,
  "cleanupPeriodDays": 60,
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(yarn run *)",
      "Bash(pnpm run *)",
      "Bash(rubocop *)",
      "Bash(prettier *)",
      "Bash(eslint *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(npm install *)",
      "Bash(pnpm install *)",
      "Bash(yarn install *)",
      "Bash(bundle install *)",
      "Bash(pytest *)",
      "Bash(rspec *)",
      "Bash(jest *)",
      "Bash(vitest *)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(secrets/**)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Write(.env)",
      "Write(.env.*)",
      "Write(secrets/**)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(git force-push *)",
      "Bash(docker *)",
      "Bash(kubectl *)",
      "Bash(rm -rf *)"
    ],
    "defaultMode": "acceptEdits"
  },
  "model": "claude-opus-4-6",
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true,
    "code-review@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "personal": {
      "source": {
        "source": "github",
        "repo": "andimrob/claude-plugins"
      }
    }
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": [
        "github.com",
        "*.github.com",
        "*.npmjs.org",
        "registry.npmjs.org",
        "rubygems.org",
        "*.rubygems.org",
        "pypi.org",
        "*.pypi.org",
        "betterconfluence.atlassian.net"
      ],
      "allowLocalBinding": true
    }
  },
  "spinnerTipsEnabled": true,
  "autoUpdatesChannel": "latest",
  "terminalProgressBarEnabled": true,
  "showTurnDuration": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/rob/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/symlink-plan.sh",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
